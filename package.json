{
  "name": "model-checker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "node scripts/cf-build.mjs",
    "preview": "wrangler pages dev out --d1=DB --persist-to=.wrangler/state",
    "cf:dev": "npm run cf:build && npm run db:local:init && npm run preview",
    "cf:deploy": "npm run cf:build && wrangler pages deploy out --project-name=model-checker",
    "db:local:init": "wrangler d1 execute model-checker --local --file=migrations/0001_initial.sql",
    "db:remote:init": "wrangler d1 execute model-checker --remote --file=migrations/0001_initial.sql",
    "lint": "eslint",
    "typecheck": "tsc --noEmit && tsc -p functions/tsconfig.json"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.25.0"
  }
}
